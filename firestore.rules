rules_version = '2';

// Lusail Café — Firestore security rules.
// Public content is world-readable; only signed-in admins can write.
// Tighten isAdmin() with your email(s) once you know them (see comment below).
service cloud.firestore {
  match /databases/{database}/documents {

    // ⚠️ SECURITY: this currently allows ANY authenticated user to write. Because
    // Email/Password sign-up is reachable via Firebase's public API, a stranger
    // could self-register and then write. STRONGLY recommended: restrict to your
    // admin email(s) by replacing the return below with the commented line.
    function isAdmin() {
      return request.auth != null;
      // return request.auth != null && request.auth.token.email in ['you@example.com'];
    }

    match /menu/{doc}       { allow read: if true; allow write: if isAdmin(); }
    match /gallery/{doc}    { allow read: if true; allow write: if isAdmin(); }
    match /signatures/{doc} { allow read: if true; allow write: if isAdmin(); }
    match /branches/{doc}   { allow read: if true; allow write: if isAdmin(); }
    match /reviews/{doc}    { allow read: if true; allow write: if isAdmin(); }
    match /settings/{doc}   { allow read: if true; allow write: if isAdmin(); }

    // Contact form: anyone may submit; only admins can read / manage.
    match /messages/{doc} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
